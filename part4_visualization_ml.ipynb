
# TASK 4: String Manipulation Utility


essay = "  python is a versatile language. it supports object oriented, functional, and procedural programming. python is widely used in data science and machine learning.  "

# 1. Erase the smudges (Strip)
clean_essay = essay.strip()
print("--- Task 4 Outputs ---")
print("1. Cleaned Essay:")
print(clean_essay)

# 2. Make them stand up straight (Title Case)
print("\n2. Title Case Essay:")
print(clean_essay.title())

# 3. Play hide and seek (Count)
python_count = clean_essay.count("python")
print("\n3. Number of times 'python' appears:")
print(python_count)

# 4. Add the snake sticker (Replace)
replaced_essay = clean_essay.replace("python", "Python 🐍")
print("\n4. Replaced Essay:")
print(replaced_essay)

# 5. Use the scissors (Split)
sentences_list = clean_essay.split(". ")
print("\n5. List of Sentences:")
print(sentences_list)

# 6. Number them and check for missing periods
print("\n6. Numbered Sentences:")
# We use 'enumerate' to automatically count 1, 2, 3 as we loop through the list
for index, sentence in enumerate(sentences_list, start=1):
    
    # Check if the sentence is missing its period at the end
    if not sentence.endswith("."):
        sentence = sentence + "."
        
    # Print the number, the dot, and the sentence
    print(f"{index}. {sentence}")